---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero';
import { getCollection } from 'astro:content';

// Pour l'instant on simule les dernières actualités
const dernieresAventures = [
  { title: "Sortie handiski avec l’USJC", date: "Mars 2026", img: "https://images.unsplash.com/photo-1551698618-1dfe5d97d256?auto=format&fit=crop&q=80&w=600" },
  { title: "Winter trail de Saint Pierre de chartreuse", date: "Février 2026", img: "https://images.unsplash.com/photo-1552066344-2464c1bf39be?auto=format&fit=crop&q=80&w=600" },
  { title: "Journée handiski à Chamrousse", date: "Janvier 2026", img: "https://images.unsplash.com/photo-1486334803289-1623f249dd1e?auto=format&fit=crop&q=80&w=600" }
];
---

<Layout title="The Rolling Adventurers - L'Aventure accessible à tous">
  <Hero />

  <main>
    <!-- Section Mission -->
    <section id="mission" class="py-24 px-4 bg-slate-950">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-5xl font-bold mb-8 text-white">Notre <span class="text-orange-500">Mission</span></h2>
        <p class="text-lg md:text-xl text-slate-400 leading-relaxed">
          Créée en 2021, notre association a pour but de promouvoir la mobilité des personnes à mobilité réduite. 
          Par l'acquisition de matériels comme les joëlettes électriques et l'organisation de sorties alpines, 
          nous transformons chaque obstacle en une nouvelle aventure.
        </p>
      </div>
    </section>

    <!-- Section Dernières Aventures -->
    <section class="py-24 px-4 bg-slate-900">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center text-white">Dernières <span class="text-orange-500">Aventures</span></h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {dernieresAventures.map((aventure) => (
            <article class="group relative overflow-hidden rounded-2xl bg-slate-800 border border-white/5 transition-all hover:-translate-y-2">
              <div class="aspect-video overflow-hidden">
                <img src={aventure.img} alt={aventure.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
              </div>
              <div class="p-6">
                <span class="text-sm text-orange-400 font-medium">{aventure.date}</span>
                <h3 class="mt-2 text-xl font-bold text-white group-hover:text-orange-500 transition-colors">{aventure.title}</h3>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

  <footer class="py-12 text-center text-slate-500 border-t border-white/5">
    <p>&copy; 2026 The Rolling Adventurers. Tous droits réservés.</p>
  </footer>
</Layout>
