---
import Layout from '../layouts/Layout.astro';
// Contenu chargé directement pour le moment
---

<Layout title="L'Association - The Rolling Adventurers">
  <main class="pt-32 px-4 pb-24 max-w-4xl mx-auto">
    <h1 class="text-4xl md:text-6xl font-bold mb-8 text-white">Notre <span class="text-orange-500">Histoire</span></h1>
    
    <article class="prose prose-invert prose-lg max-w-none">
      {asso ? (
        <astro-island client:load>
          <div class="whitespace-pre-line text-slate-300">
            {asso.body}
          </div>
        </astro-island>
      ) : (
        <p>Chargement du contenu...</p>
      )}
    </article>

    <div class="mt-16 p-8 bg-slate-900 rounded-2xl border border-white/5">
      <h2 class="text-2xl font-bold text-white mb-4">Nos Valeurs</h2>
      <ul class="space-y-4 text-slate-300">
        <li class="flex items-center"><span class="text-orange-500 mr-2">●</span> <strong>Solidarité :</strong> Personne ne reste sur le bord du chemin.</li>
        <li class="flex items-center"><span class="text-orange-500 mr-2">●</span> <strong>Dépassement :</strong> Repousser les limites, ensemble.</li>
        <li class="flex items-center"><span class="text-orange-500 mr-2">●</span> <strong>Partage :</strong> Des souvenirs inoubliables pour tous.</li>
      </ul>
    </div>
  </main>
</Layout>
